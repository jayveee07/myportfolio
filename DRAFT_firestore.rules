rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "jvpaisan@gmail.com" ||
        request.auth.uid == "IrWAuYlvLkOSBOIljYrxXP7dVye2"
      );
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_.@\\-]+$');
    }

    // --- Entity Validations ---

    function isValidVisit(data) {
      return data.timestamp == request.time &&
             data.lastActive == request.time &&
             data.visitorId is string &&
             data.visitorId.size() <= 200 &&
             (!('email' in data) || data.email == null || (data.email is string && data.email.size() <= 200));
    }

    function isValidConversation(data) {
      let requiredFields = ['participants', 'updatedAt', 'visitorEmail', 'visitorName', 'visitorUid', 'visitorId', 'visitorIp', 'unreadCount', 'isAutoReplied'];
      return data.participants is list &&
             data.participants.size() == 2 &&
             data.updatedAt == request.time &&
             data.visitorEmail is string &&
             data.visitorEmail.size() <= 200 &&
             data.visitorName is string &&
             data.visitorName.size() <= 200 &&
             data.visitorUid == request.auth.uid &&
             data.unreadCount is int &&
             data.isAutoReplied is bool &&
             (!('visitorAvatar' in data) || data.visitorAvatar == null || (data.visitorAvatar is string && data.visitorAvatar.size() <= 200000));
    }

    function isValidMessage(data) {
      return data.text is string &&
             data.text.size() > 0 &&
             data.text.size() <= 10000 &&
             data.createdAt == request.time &&
             data.senderId is string &&
             data.senderId.size() <= 200;
    }

    // --- Collections ---

    // Public Collections
    match /userProfile/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /experience/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /skills/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /projects/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/chat {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Visits
    match /visits/{visitId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidVisit(incoming()) && isValidId(visitId);
      allow update: if (isAdmin() || isSignedIn()) && 
                    incoming().lastActive == request.time && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['lastActive', 'path', 'visitorId', 'ip', 'userAgent']);
    }

    // Conversations
    match /conversations/{conversationId} {
      // Security Pillar 8: Enforce query boundaries
      allow list: if isAdmin() || (isSignedIn() && resource.data.visitorUid == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && conversationId.startsWith('vst_'));
      
      allow create: if isSignedIn() && 
                    conversationId.startsWith('vst_') && 
                    isValidId(conversationId) && 
                    isValidConversation(incoming());
                    
      allow update: if isAdmin() || (
        isSignedIn() && 
        conversationId.startsWith('vst_') && 
        !existing().get('isBlocked', false) &&
        (
          // Action: Heartbeat/Typing
          incoming().diff(existing()).affectedKeys().hasOnly(['visitorTyping', 'updatedAt', 'visitorIp', 'visitorUid', 'visitorId', 'visitorAvatar']) ||
          // Action: Admin updates
          isAdmin()
        )
      );

      // Messages Subcollection
      match /messages/{messageId} {
        function canAccessConvo() {
          let convo = get(/databases/$(database)/documents/conversations/$(conversationId)).data;
          return isAdmin() || convo.visitorUid == request.auth.uid;
        }

        allow list: if isAdmin() || (isSignedIn() && conversationId.startsWith('vst_'));
        allow get: if isAdmin() || (isSignedIn() && conversationId.startsWith('vst_'));
        
        allow create: if isSignedIn() && 
                      isValidMessage(incoming()) && 
                      (isAdmin() || (
                        conversationId.startsWith('vst_') && 
                        !get(/databases/$(database)/documents/conversations/$(conversationId)).data.get('isBlocked', false)
                      ));
        
        allow update: if isAdmin() || (
          isSignedIn() && 
          conversationId.startsWith('vst_') &&
          existing().senderId != "admin" &&
          !get(/databases/$(database)/documents/conversations/$(conversationId)).data.get('isBlocked', false) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['text', 'isEdited', 'deletedBy']) &&
          (request.time.toMillis() - existing().createdAt.toMillis() < 10 * 60 * 1000)
        );
        
        allow delete: if isAdmin() || (
          isSignedIn() && 
          conversationId.startsWith('vst_') && 
          existing().senderId != "admin"
        );
      }
    }
  }
}
