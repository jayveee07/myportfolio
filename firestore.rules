rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isAdmin() { 
      // Only include specific admin checks if user is logged in and has the verified admin email
      return isSignedIn() && 
             request.auth.token != null &&
             "email" in request.auth.token && 
             request.auth.token.email == "jvpaisan@gmail.com" &&
             request.auth.token.email_verified == true;
    }
    
    function isVisitorPath(cid) {
      // Robust path detection for visitor conversations
      return cid != null && cid is string && cid.startsWith("vst_");
    }

    // --- Portfolio Rules (Public) ---
    match /userProfile/main { allow read: if true; allow write: if isAdmin(); }
    match /experience/{id} { allow read, list: if true; allow write: if isAdmin(); }
    match /skills/{id} { allow read, list: if true; allow write: if isAdmin(); }
    match /projects/{id} { allow read, list: if true; allow write: if isAdmin(); }
    match /test/connection { allow read: if true; }

    // --- Visitor Tracking ---
    match /visits/{visitId} {
      allow read, write: if true;
    }

    // --- Private Messaging ---
    match /conversations/{conversationId} {
      // Explicitly allow visitors to interact with documents that follow the naming convention
      // This is the primary security gate for the chat system
      allow get, write: if isVisitorPath(conversationId) || isAdmin();
      allow list: if isAdmin();
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read, write: if isVisitorPath(conversationId) || isAdmin();
      }
    }
    
    // Catch-all deny for any other collections to prevent data leaks
    match /{anyCollection}/{anyDoc} {
      allow read, write: if isAdmin();
    }
  }
}
