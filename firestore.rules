rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email == "jvpaisan@gmail.com";
    }
    
    function isParticipant(cid) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/conversations/$(cid)) &&
             request.auth.uid in get(/databases/$(database)/documents/conversations/$(cid)).data.participants;
    }

    function incoming() { return request.resource.data; }

    // --- Validation Schemas ---
    function isValidMessage(data) {
      return data.keys().hasAll(['conversationId', 'text', 'senderId', 'senderName', 'createdAt']) &&
             data.text is string && data.text.size() <= 3000 &&
             data.senderId is string &&
             data.createdAt == request.time;
    }

    // --- Portfolio Rules (Public) ---
    match /userProfile/main { allow read: if true; allow write: if isAdmin(); }
    match /experience/{id} { allow read: if true; allow write: if isAdmin(); }
    match /skills/{id} { allow read: if true; allow write: if isAdmin(); }
    match /projects/{id} { allow read: if true; allow write: if isAdmin(); }
    match /test/connection { allow read: if true; }

    // --- Private Messaging ---
    match /conversations/{conversationId} {
      allow create: if isSignedIn();
      allow list: if isAdmin();
      // Allow get to check existence/metadata
      allow get: if isSignedIn();
      // Allow update if admin or adding oneself to participants
      allow update: if isAdmin() || (isSignedIn() && (
        request.auth.uid in resource.data.participants || 
        (request.resource.data.participants.hasAll(resource.data.participants) && 
         request.auth.uid in request.resource.data.participants)
      ));

      match /messages/{messageId} {
        allow read, list, get: if isAdmin() || isParticipant(conversationId);
        allow create: if (isAdmin() || isParticipant(conversationId)) && isValidMessage(incoming());
      }
    }
  }
}
