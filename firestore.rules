rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Safety Net ---
    // match /{document=**} {
    //   allow read, write: if false;
    // }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '') == "jvpaisan@gmail.com" ||
        request.auth.uid == "IrWAuYlvLkOSBOIljYrxXP7dVye2"
      );
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 256 && id.matches('^[a-zA-Z0-9_.@\\s\\-:_]+$');
    }

    // --- Entity Validations ---

    function isValidVisit(data) {
      return data.get('visitorId', '') is string &&
             data.get('visitorId', '').size() <= 500;
    }

    function isValidConversation(data) {
      return (data.get('visitorEmail', '') is string || !('visitorEmail' in data));
    }

    function isValidMessage(data) {
      return data.get('text', '') is string &&
             data.get('text', '').size() > 0 &&
             data.get('senderId', '') is string;
    }

    // Health Check / Test Connection
    match /test/connection {
      allow get: if true;
    }

    // --- Collections ---

    // Public Collections
    match /userProfile/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /experience/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /skills/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /projects/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/chat {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Visits
    match /visits/{visitId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(visitId);
      allow update: if isSignedIn() && isValidId(visitId);
    }

    // Conversations
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && (isAdmin() || conversationId.startsWith('vst_'));
      allow create: if isSignedIn() && conversationId.startsWith('vst_');
      allow update: if isSignedIn() && (isAdmin() || conversationId.startsWith('vst_'));
      allow delete: if isAdmin();

      // Messages Subcollection
      match /messages/{messageId} {
        allow read: if isSignedIn() && (isAdmin() || conversationId.startsWith('vst_'));
        allow create: if isSignedIn() && (isAdmin() || conversationId.startsWith('vst_'));
        allow update: if isSignedIn() && (isAdmin() || conversationId.startsWith('vst_'));
        allow delete: if isAdmin();
      }
    }

    // Visitor Identity Records (Syncing Email to UID)
    match /users/{email} {
      function isValidVisitorRecord(data) {
        return (data.get('email', '') is string || !('email' in data)) && 
               data.uid is string && 
               data.uid == request.auth.uid;
      }
      
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidId(email) && isValidVisitorRecord(incoming()) && incoming().email == email;
      allow update: if isSignedIn() && isValidId(email) && isValidVisitorRecord(incoming());
      allow list: if isAdmin();
    }
  }
}
