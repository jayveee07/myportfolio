rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Safety Net ---
    // match /{document=**} {
    //   allow read, write: if false;
    // }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '') == "jvpaisan@gmail.com" ||
        request.auth.uid == "IrWAuYlvLkOSBOIljYrxXP7dVye2"
      );
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 256 && id.matches('^[a-zA-Z0-9_.@\\s\\-:_]+$');
    }

    // --- Entity Validations ---

    function isValidVisit(data) {
      return data.get('visitorId', '') is string &&
             data.get('visitorId', '').size() <= 500;
    }

    function isValidConversation(data) {
      return (data.get('visitorEmail', '') is string || !('visitorEmail' in data));
    }

    function isValidMessage(data) {
      return data.get('text', '') is string &&
             data.get('text', '').size() > 0 &&
             data.get('senderId', '') is string;
    }

    // Health Check / Test Connection
    match /test/connection {
      allow get: if true;
    }

    // --- Collections ---

    // Public Collections
    match /userProfile/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /experience/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /skills/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /projects/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/chat {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /visits/{visitId} {
      allow read, write: if true;
    }

    match /conversations/{conversationId} {
      allow read, write: if isSignedIn();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /users/{email} {
      allow read, write: if isSignedIn();
    }
  }
}
